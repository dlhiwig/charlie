{
  "gateway": {
    "port": 18797,
    "bind": "127.0.0.1",
    "authToken": "bravo-gateway-auth-token-2026"
  },
  "telegram": {
    "botToken": "${TELEGRAM_BOT_TOKEN}",
    "allowFrom": ["938702109"]
  },
  "models": {
    "primary": "anthropic/claude-sonnet-4-20250514",
    "fallbacks": [
      "openai/gpt-4.1",
      "xai/grok-3-mini-fast",
      "ollama/qwen3.5:27b",
      "ollama/qwen3.5:9b"
    ],
    "specialists": {
      "deepReasoning": "ollama/nemotron-3-super:latest",
      "codeAudit": "ollama/nemotron-3-super:latest",
      "securityAnalysis": "ollama/nemotron-3-super:latest"
    },
    "providers": {
      "ollama": {
        "baseUrl": "http://127.0.0.1:11434/v1",
        "apiKey": "ollama",
        "models": [
          {
            "id": "nemotron-3-super:latest",
            "name": "Nemotron-3-Super 120B (Specialist)",
            "contextWindow": 262144,
            "maxTokens": 32768,
            "requiresGPU": true,
            "specialtyUse": ["audit", "security", "analysis", "deep reasoning", "formal verification"],
            "fallbackOnly": false
          },
          {
            "id": "qwen3.5:27b",
            "name": "Qwen 3.5 27B (Balanced)",
            "contextWindow": 131072,
            "maxTokens": 16384
          },
          {
            "id": "qwen3.5:9b",
            "name": "Qwen 3.5 9B (Fast)",
            "contextWindow": 131072,
            "maxTokens": 8192
          }
        ]
      },
      "anthropic": {
        "baseUrl": "https://api.anthropic.com",
        "apiKey": "${ANTHROPIC_API_KEY}",
        "models": [
          {
            "id": "claude-sonnet-4-20250514",
            "name": "Claude Sonnet-4",
            "contextWindow": 200000,
            "maxTokens": 8192
          }
        ]
      },
      "openai": {
        "baseUrl": "https://api.openai.com/v1",
        "apiKey": "${OPENAI_API_KEY}",
        "models": [
          {
            "id": "gpt-4.1",
            "name": "GPT-4.1",
            "contextWindow": 128000,
            "maxTokens": 4096
          }
        ]
      },
      "xai": {
        "baseUrl": "https://api.x.ai/v1",
        "apiKey": "${XAI_API_KEY}",
        "models": [
          {
            "id": "grok-3-mini-fast",
            "name": "Grok 3 Mini",
            "contextWindow": 131072,
            "maxTokens": 4096
          }
        ]
      }
    }
  },
  "ollama": {
    "endpoint": "http://127.0.0.1:11434",
    "gpu": {
      "enabled": true,
      "deviceId": 0,
      "memoryFraction": 0.8
    }
  },
  "skynet": {
    "enabled": true,
    "governance": {
      "maxTokensPerRequest": 32768,
      "rateLimitPerMinute": 60,
      "autoEscalation": true
    }
  },
  "stateDir": "~/.bravo",
  "tools": {
    "webSearch": {
      "enabled": true,
      "provider": "brave",
      "apiKey": "${BRAVE_SEARCH_API_KEY}",
      "defaults": {
        "country": "US",
        "search_lang": "en",
        "safesearch": "moderate",
        "maxResults": 10
      }
    }
  },
  "logging": {
    "level": "info",
    "file": "~/.bravo/bravo.log"
  }
}