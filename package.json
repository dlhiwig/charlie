{
  "name": "charlie",
  "version": "1.0.0",
  "description": "Charlie — Standalone AI Runtime. Pure TypeScript bot framework with zero dependencies.",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "node --test src/**/*.test.ts"
  },
  "dependencies": {
    "@fastify/websocket": "^11.0.2",
    "@sinclair/typebox": "^0.34.48",
    "better-sqlite3": "^11.9.1",
    "dotenv": "^16.5.0",
    "fastify": "^5.2.0",
    "grammy": "^1.41.1",
    "openai": "^5.3.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.1.3",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "author": "Daniel Heiwig",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dlhiwig/charlie.git"
  }
}
